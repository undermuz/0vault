{
	"name": "0vault",
	"version": "1.1.0",
	"description": "Encrypted .age vault editor with archive support — store passwords and secrets safely anywhere",
	"scripts": {
		"test": "bun test src/di/vault/archive src/di/bun/vault-age",
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:stable": "vite build && electrobun build --env=stable"
	},
	"dependencies": {
		"@heroui/react": "^3.1.0",
		"@heroui/styles": "^3.1.0",
		"@logtape/logtape": "^2.1.3",
		"age-encryption": "^0.3.0",
		"electrobun": "1.16.0",
		"fflate": "^0.8.3",
		"i18n-js": "^4.5.3",
		"inversify": "^8.1.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"reflect-metadata": "^0.2.2",
		"valtio": "^2.3.2"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"concurrently": "^10.0.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	}
}
