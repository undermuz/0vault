{
	"name": "0vault",
	"version": "1.1.0",
	"description": "Encrypted .age vault editor with archive support — store passwords and secrets safely anywhere",
	"scripts": {
		"test": "bun test src/di/vault/archive src/di/bun/vault-age",
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:stable": "vite build && electrobun build --env=stable"
	},
	"dependencies": {
		"age-encryption": "^0.3.0",
		"electrobun": "1.16.0",
		"fflate": "^0.8.2",
		"inversify": "^7.11.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"reflect-metadata": "^0.2.2",
		"valtio": "^2.1.5",
		"i18n-js": "^4.5.1",
		"@logtape/logtape": "^2.0.4"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}